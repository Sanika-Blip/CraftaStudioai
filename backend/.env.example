# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3004
NODE_ENV=development

# ─── Database (Railway PostgreSQL) ────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway"

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://YOUR-INSTANCE.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"
REDIS_URL="rediss://default:YOUR_TOKEN@YOUR-INSTANCE.upstash.io:6379"

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_YOUR_KEY
CLERK_JWKS_URL=https://YOUR-CLERK-DOMAIN.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER_URL=https://YOUR-CLERK-DOMAIN.clerk.accounts.dev

# ─── LangFuse (Optional, for LLM tracing) ────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-YOUR_KEY
LANGFUSE_PUBLIC_KEY=pk-lf-YOUR_KEY
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Cloudflare R2 (Optional, for file storage) ──────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=YOUR_ACCOUNT_ID
CLOUDFLARE_R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY
CLOUDFLARE_R2_SECRET_ACCESS_KEY=YOUR_SECRET
CLOUDFLARE_R2_BUCKET_NAME=craftastudio-prod-files
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# ─── Agent Service ────────────────────────────────────────────────────────────
AGENT_SERVICE_URL=http://localhost:8000

# ─── Sarvam AI ────────────────────────────────────────────────────────────────
SARVAM_API_KEY=YOUR_KEY
SARVAM_MODEL=sarvam-30b
