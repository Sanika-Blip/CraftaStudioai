generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ✅ ENUM (NEW)
enum RunStatus {
  pending
  running
  done
  failed
}

// ─────────────────────────────────────────
// User
// ─────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams Team[]

  @@map("User")
}

// ─────────────────────────────────────────
// Team
// ─────────────────────────────────────────
model Team {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projects Project[]

  @@index([userId])
  @@map("teams")
}

// ─────────────────────────────────────────
// Project
// ─────────────────────────────────────────
model Project {
  id           String        @id @default(uuid())
  teamId       String
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  blocks       Block[]
  connections  Connection[]
  workflowRuns WorkflowRun[]

  @@index([teamId])
  @@map("projects")
}

// ─────────────────────────────────────────
// Block
// ─────────────────────────────────────────
model Block {
  id                String        @id @default(uuid())
  projectId         String
  blockType         String
  blockJson         Json
  version           String        @default("1.0.0")
  lastGeneratedHash String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outConnections    Connection[]  @relation("FromBlock")
  inConnections     Connection[]  @relation("ToBlock")
  blockOutputs      BlockOutput[]

  @@index([projectId])
  @@index([blockType])
  @@map("blocks")
}

// ─────────────────────────────────────────
// Connection
// ─────────────────────────────────────────
model Connection {
  id             String   @id @default(uuid())
  projectId      String
  fromBlockId    String
  toBlockId      String
  connectionType String   @default("dependency")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromBlock Block   @relation("FromBlock", fields: [fromBlockId], references: [id], onDelete: Cascade)
  toBlock   Block   @relation("ToBlock", fields: [toBlockId], references: [id], onDelete: Cascade)

  @@unique([fromBlockId, toBlockId])
  @@index([projectId])
  @@map("connections")
}

// ─────────────────────────────────────────
// WorkflowRun
// ─────────────────────────────────────────
model WorkflowRun {
  id                String     @id @default(uuid())
  projectId         String
  prompt            String
  status            RunStatus
  version           Int        @default(1)
  sharedContextJson Json
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  project      Project       @relation(fields: [projectId], references: [id])
  blockOutputs BlockOutput[]

  @@index([projectId])
}

// ─────────────────────────────────────────
// BlockOutput
// ─────────────────────────────────────────
model BlockOutput {
  id         String     @id @default(uuid())
  runId      String
  blockId    String
  blockType  String
  outputCode String
  tokensUsed Int        @default(0)
  status     RunStatus  @default(pending)
  errorMsg   String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  run   WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  block Block       @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([blockId])
  @@map("block_outputs")
}