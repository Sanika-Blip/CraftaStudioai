generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RunStatus {
  pending
  running
  awaiting_confirm
  done
  failed
}

enum ConflictSeverity {
  low
  medium
  high
}

enum JobType {
  frontend
  backend
  planner
  merge
}

enum MemoryType {
  architecture_decision
  preference
  constraint
  event
  pattern
}

enum Priority {
  high
  medium
  low
}

enum MemorySource {
  user
  system
  inferred
}

enum ConflictType {
  syntax
  dependency
  logic
}

enum ConnectionType {
  dependency
  data_flow
  trigger
}

enum TeamRole {
  owner
  admin
  member
}
enum DocumentStatus {
  pending
  approved
  rejected
}

// ─────────────────────────────────────────
// User
// ─────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamMemberships TeamMember[]
  workflowRuns    WorkflowRun[]  // runs initiated by this user
  jobRuns         JobRun[]       // jobs initiated by this user
  conflictLogs    ConflictLog[]  // conflicts attributed to this user

  @@map("users")
}

// ─────────────────────────────────────────
// Team
// ─────────────────────────────────────────
model Team {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  TeamMember[]
  projects Project[]

  @@map("teams")
}

// ─────────────────────────────────────────
// TeamMember  (join table — multi-user teams)
// ─────────────────────────────────────────
model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      TeamRole @default(member)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

// ─────────────────────────────────────────
// Project
// ─────────────────────────────────────────
model Project {
  id        String   @id @default(uuid())
  teamId    String
  name      String
  planDoc   String?  @db.Text
  document  ProjectDocument?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  blocks       Block[]
  connections  Connection[]
  workflowRuns WorkflowRun[]
  memories     Memory[]

  @@index([teamId])
  @@map("projects")
}

// ─────────────────────────────────────────
// Block
// ─────────────────────────────────────────
model Block {
  id                String   @id @default(uuid())
  projectId         String
  blockType         String
  blockJson         Json
  version           String   @default("1.0.0")
  lastGeneratedHash String?
  positionX         Float    @default(0)
  positionY         Float    @default(0)
  uiMeta            Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outConnections Connection[]  @relation("FromBlock")
  inConnections  Connection[]  @relation("ToBlock")
  blockOutputs   BlockOutput[]
  jobRuns        JobRun[]
  conflicts      ConflictLog[]

  @@unique([projectId, blockType])
  @@index([projectId])
  @@index([blockType])
  @@map("blocks")
}

// ─────────────────────────────────────────
// Connection
// ─────────────────────────────────────────
model Connection {
  id             String         @id @default(uuid())
  projectId      String
  fromBlockId    String
  toBlockId      String
  connectionType ConnectionType @default(dependency)
  sourceHandle   String?
  targetHandle   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromBlock Block   @relation("FromBlock", fields: [fromBlockId], references: [id], onDelete: Cascade)
  toBlock   Block   @relation("ToBlock", fields: [toBlockId], references: [id], onDelete: Cascade)

  @@unique([fromBlockId, toBlockId])
  @@index([projectId])
  @@index([connectionType])
  @@map("connections")
}

// ─────────────────────────────────────────
// WorkflowRun  — now tracks which user triggered it
// ─────────────────────────────────────────
model WorkflowRun {
  id                String    @id @default(uuid())
  projectId         String
  triggeredByUserId String    // ← who initiated this run
  prompt            String
  status            RunStatus
  version           Int       @default(1)
  sharedContextJson Json
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project       Project        @relation(fields: [projectId], references: [id])
  triggeredBy   User           @relation(fields: [triggeredByUserId], references: [id])
  blockOutputs  BlockOutput[]
  jobRuns       JobRun[]
  mergedOutputs MergedOutput[]
  conflicts     ConflictLog[]
  fileMetadata  FileMetadata[]

  @@index([projectId])
  @@index([triggeredByUserId])          // ← query all runs by a user
  @@index([triggeredByUserId, projectId]) // ← query runs by user + project
  @@index([createdAt])
  @@index([status])
  @@map("workflow_runs")
}

// ─────────────────────────────────────────
// BlockOutput
// ─────────────────────────────────────────
model BlockOutput {
  id         String    @id @default(uuid())
  runId      String
  blockId    String
  blockType  String
  outputCode String
  tokensUsed Int       @default(0)
  status     RunStatus @default(pending)
  errorMsg   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  run   WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  block Block       @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([blockId])
  @@index([createdAt])
  @@map("block_outputs")
}

// ─────────────────────────────────────────
// JobRun  — now tracks which user triggered it
// ─────────────────────────────────────────
model JobRun {
  id              String    @id @default(uuid())
  workflowRunId   String
  blockId         String?
  triggeredByUserId String? // ← who triggered this specific job
  jobType         JobType
  status          RunStatus @default(pending)
  logs            Json?
  errorMsg        String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  retryCount      Int       @default(0)

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  block       Block?      @relation(fields: [blockId], references: [id], onDelete: Cascade)
  triggeredBy User?       @relation(fields: [triggeredByUserId], references: [id])

  @@index([workflowRunId])
  @@index([blockId])
  @@index([triggeredByUserId])          // ← query all jobs by a user
  @@index([createdAt])
  @@index([status])
  @@index([jobType])
  @@map("job_runs")
}

// ─────────────────────────────────────────
// MergedOutput
// ─────────────────────────────────────────
model MergedOutput {
  id            String   @id @default(uuid())
  workflowRunId String
  finalCode     String
  summary       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([workflowRunId])
  @@index([createdAt])
  @@map("merged_outputs")
}

// ─────────────────────────────────────────
// ConflictLog  — now tracks which user it belongs to
// ─────────────────────────────────────────
model ConflictLog {
  id                String           @id @default(uuid())
  workflowRunId     String
  blockId           String?
  attributedUserId  String?          // ← which user's action caused this conflict
  conflictType      ConflictType
  message           String
  severity          ConflictSeverity
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  workflowRun   WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  block         Block?      @relation(fields: [blockId], references: [id], onDelete: Cascade)
  attributedTo  User?       @relation(fields: [attributedUserId], references: [id])

  @@index([workflowRunId])
  @@index([blockId])
  @@index([attributedUserId])           // ← query conflicts by user
  @@index([createdAt])
  @@map("conflict_logs")
}

// ─────────────────────────────────────────
// FileMetadata
// ─────────────────────────────────────────
model FileMetadata {
  id            String   @id @default(uuid())
  workflowRunId String
  fileName      String
  fileType      String
  fileSize      Int
  fileUrl       String?
  storageKey    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([workflowRunId])
  @@index([createdAt])
  @@map("file_metadata")
}

// ─────────────────────────────────────────
// Memory
// ─────────────────────────────────────────
model Memory {
  id        String @id @default(uuid())
  projectId String

  type  MemoryType
  key   String
  value Json

  confidence Float         @default(0.5)
  priority   Priority      @default(medium)
  source     MemorySource?
  isConflict Boolean       @default(false)

  usageCount Int       @default(0)
  lastUsedAt DateTime?
  version    Int       @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId, type, confidence])
  @@index([projectId])
  @@index([type])
  @@index([key])
  @@index([projectId, type])
  @@index([confidence])
  @@index([projectId, key, version])
  @@index([updatedAt])
  @@index([priority])
  @@map("memories")
}

// ─────────────────────────────────────────
// ProjectDocument
// ─────────────────────────────────────────
model ProjectDocument {
  id        String         @id @default(uuid())
  projectId String         @unique
  content   String
  status    DocumentStatus @default(pending)
  version   Int            @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_documents")
}


